# AI Model API Keys (set at least one)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=...

# Browser settings
# BROWSER_HEADLESS=false
# BROWSER_BINARY_PATH=/usr/bin/chromium
# BROWSER_USER_DATA_DIR=~/.config/chromium
# BROWSER_DISABLE_SECURITY=true

# Proxy
# OPEN_BROWSER_PROXY_SERVER=http://proxy:8080
# OPEN_BROWSER_PROXY_USERNAME=user
# OPEN_BROWSER_PROXY_PASSWORD=pass

# Traces and recordings
# OPEN_BROWSER_TRACE_PATH=./traces
# OPEN_BROWSER_SAVE_RECORDING_PATH=./recordings
